[Unit]
Description=CartoSky ECMWF Scheduler (CONUS canonical)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=cartosky
Group=cartosky
UMask=0027
LimitNOFILE=65536
WorkingDirectory=/opt/cartosky/backend
EnvironmentFile=-/etc/cartosky/scheduler-ecmwf.env
Environment=PATH=/opt/cartosky/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
# Bound the GDAL raster block cache (MB). Matches the cap operators set on the
# live scheduler units 2026-07 (EPS memory audit); without it GDAL defaults to
# 5% of RAM per process.
Environment=GDAL_CACHEMAX=256
ExecStart=/opt/cartosky/.venv/bin/python -m app.services.scheduler --model ecmwf
Nice=10
CPUWeight=50
IOWeight=50
# Optional hard cap if needed for noisy neighbors / OOM protection:
# MemoryMax=2G
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target