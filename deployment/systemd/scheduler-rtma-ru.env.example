# Copy to: /etc/cartosky/scheduler-rtma-ru.env
CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_CURRENT_ANALYSIS_CACHE_DIR=/opt/cartosky/herbie_cache/current_analysis
CARTOSKY_CURRENT_ANALYSIS_PRODUCT=anl
CARTOSKY_CURRENT_ANALYSIS_POLL_SECONDS=300
CARTOSKY_CURRENT_ANALYSIS_KEEP_RUNS=6
CARTOSKY_CURRENT_ANALYSIS_WINDOW_MINUTES=120
CARTOSKY_CURRENT_ANALYSIS_FRAME_CADENCE_MINUTES=15
CARTOSKY_CURRENT_ANALYSIS_LOOKBACK_MINUTES=360
CARTOSKY_CURRENT_ANALYSIS_SOURCE_PRIORITY=aws,nomads
CARTOSKY_CURRENT_ANALYSIS_ALLOW_GRIB_WITHOUT_IDX=0