# Copy to: /etc/cartosky/scheduler-nam.env
CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_WORKERS=4
CARTOSKY_SCHEDULER_VARS=auto
CARTOSKY_SCHEDULER_PRIMARY_VARS=tmp2m
CARTOSKY_SCHEDULER_POLL_SECONDS=300
CARTOSKY_SCHEDULER_KEEP_RUNS=4
CARTOSKY_SCHEDULER_PROBE_VAR=tmp2m
CARTOSKY_GRIB_DISK_CACHE_LOCK=1
HERBIE_SAVE_DIR=/opt/cartosky/herbie_cache

# Herbie subset fetch controls (subset-only, no full-file fallback)
CARTOSKY_HERBIE_PRIORITY=aws,nomads,google
CARTOSKY_HERBIE_SUBSET_RETRIES=2
CARTOSKY_HERBIE_RETRY_SLEEP_SECONDS=1.0
