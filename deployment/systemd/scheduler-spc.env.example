# CartoSky SPC poller configuration
CARTOSKY_SPC_DATA_ROOT=/opt/cartosky/data
CARTOSKY_SPC_POLL_SECONDS=900
CARTOSKY_SPC_KEEP_RUNS=10
CARTOSKY_SPC_TIMEOUT_SECONDS=30
# Optional override for testing or proxying the NOAA/SPC service.
# CARTOSKY_SPC_BASE_URL=https://mapservices.weather.noaa.gov/vector/rest/services/outlooks/SPC_wx_outlks/FeatureServer