# Copy to: /etc/cartosky/scheduler-eps.env
CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_WORKERS=3
CARTOSKY_SCHEDULER_VARS=auto
CARTOSKY_SCHEDULER_PRIMARY_VARS=tmp2m
CARTOSKY_SCHEDULER_POLL_SECONDS=300
CARTOSKY_SCHEDULER_KEEP_RUNS=4
CARTOSKY_SCHEDULER_PROBE_VAR=tmp2m
CARTOSKY_DERIVE_BUNDLE=1
CARTOSKY_GRIB_DISK_CACHE_LOCK=1

# Herbie fetch controls
CARTOSKY_HERBIE_PRIORITY=azure,aws,ecmwf
CARTOSKY_HERBIE_SUBSET_RETRIES=2
CARTOSKY_HERBIE_RETRY_SLEEP_SECONDS=1.0
HERBIE_SAVE_DIR=/opt/cartosky/herbie_cache

# Optional EPS full-file scratch cache for same-hour reuse across variables.
# Keep this on local scratch storage and cap it aggressively.
CARTOSKY_EPS_FULL_FILE_CACHE_ENABLE=1
# CARTOSKY_EPS_FULL_FILE_CACHE_ROOT=/var/cache/cartosky/eps
# CARTOSKY_EPS_FULL_FILE_CACHE_MAX_BYTES=214748364800
# CARTOSKY_EPS_FULL_FILE_CACHE_TTL_SECONDS=7200