# Copy to: /etc/cartosky/serving-canary.env
# Serving canary: periodically fetches a grid file through Cloudflare, times it,
# and exposes Prometheus metrics. Runs on the origin box, so it measures the
# origin<->Cloudflare segment and the nearby CF edge -- not the user last-mile.

# API base URL to probe (Cloudflare-fronted public host).
CARTOSKY_CANARY_BASE_URL=https://api.cartosky.com
# Model id whose latest run is fetched.
CARTOSKY_CANARY_MODEL=mrms
# Variable id whose grid file is fetched.
CARTOSKY_CANARY_VAR=reflectivity
# Seconds between probe cycles.
CARTOSKY_CANARY_INTERVAL_SECONDS=300
# Prometheus metrics port (scraped at 127.0.0.1:<port>/metrics).
CARTOSKY_CANARY_METRICS_PORT=9105
# Hard per-request wall-clock timeout; a fetch past this is abandoned and
# recorded as a slow/failed probe.
CARTOSKY_CANARY_FETCH_TIMEOUT_SECONDS=90
