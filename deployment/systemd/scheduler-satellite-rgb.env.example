# GOES RGB True Color scheduler configuration
# Copy to /etc/cartosky/scheduler-satellite-rgb.env and adjust as needed.

CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_GOES_RGB_CACHE_DIR=/opt/cartosky/goes_rgb_cache
CARTOSKY_GOES_RGB_SATELLITE=goes19
CARTOSKY_GOES_RGB_BUCKET=noaa-goes19
CARTOSKY_GOES_RGB_SECTOR=C
CARTOSKY_GOES_RGB_POLL_SECONDS=120
CARTOSKY_GOES_RGB_KEEP_RUNS=6
CARTOSKY_GOES_RGB_WINDOW_MINUTES=90
CARTOSKY_GOES_RGB_FRAME_CADENCE_MINUTES=5
CARTOSKY_GOES_RGB_LISTING_LOOKBACK_HOURS=3
CARTOSKY_GOES_RGB_OBJECT_MIN_AGE_SECONDS=120
CARTOSKY_GOES_RGB_COMPOSITE=cimss_true_color_sunz_rayleigh
CARTOSKY_GOES_RGB_WEBP_QUALITY=85