# CartoSky WPC poller configuration
CARTOSKY_WPC_DATA_ROOT=/opt/cartosky/data
CARTOSKY_WPC_LISTING_URL=https://ftp.wpc.ncep.noaa.gov/5km_qpf/
CARTOSKY_WPC_POLL_SECONDS=3600
CARTOSKY_WPC_KEEP_RUNS=8
CARTOSKY_WPC_TIMEOUT_SECONDS=30
CARTOSKY_WPC_MAX_FORECAST_HOURS=168
CARTOSKY_WPC_FORECAST_STEP_HOURS=6