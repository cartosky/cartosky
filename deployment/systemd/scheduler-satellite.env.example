# Copy to: /etc/cartosky/scheduler-satellite.env
CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_GOES_PROVIDER=noaa
CARTOSKY_GOES_SATELLITE=goes19
CARTOSKY_GOES_BUCKET=noaa-goes19
CARTOSKY_GOES_PRODUCT=ABI-L2-CMIPC
CARTOSKY_GOES_SECTOR=C
CARTOSKY_GOES_BANDS=13,9
CARTOSKY_GOES_POLL_SECONDS=300
CARTOSKY_GOES_KEEP_RUNS=6
CARTOSKY_GOES_WINDOW_MINUTES=180
CARTOSKY_GOES_FRAME_CADENCE_MINUTES=15
CARTOSKY_GOES_LISTING_LOOKBACK_HOURS=5
CARTOSKY_GOES_OBJECT_MIN_AGE_SECONDS=120
CARTOSKY_GOES_MIN_OBJECT_BYTES=1000000
CARTOSKY_GOES_CACHE_DIR=/opt/cartosky/goes_cache
