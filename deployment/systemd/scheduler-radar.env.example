# Copy to: /etc/cartosky/scheduler-radar.env
CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_MRMS_LISTING_URL=https://mrms.ncep.noaa.gov/2D/MergedBaseReflectivityQC/
CARTOSKY_MRMS_PRECIP_FLAG_LISTING_URL=https://mrms.ncep.noaa.gov/2D/PrecipFlag/
CARTOSKY_MRMS_POLL_SECONDS=120
CARTOSKY_MRMS_KEEP_RUNS=6
CARTOSKY_MRMS_WINDOW_MINUTES=120
CARTOSKY_MRMS_FRAME_CADENCE_MINUTES=5
CARTOSKY_MRMS_LISTING_TIMEOUT_SECONDS=15
CARTOSKY_MRMS_DOWNLOAD_TIMEOUT_SECONDS=30
CARTOSKY_MRMS_PREFERRED_DECODER=pygrib
CARTOSKY_MRMS_FALLBACK_DECODER=pygrib
CARTOSKY_MRMS_FRAME_WRITE_WORKERS=1
CARTOSKY_MRMS_MAX_DECODE_FRAMES_PER_CYCLE=8
