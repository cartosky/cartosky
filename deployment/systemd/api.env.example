CARTOSKY_DATA_ROOT=/opt/cartosky/data
CARTOSKY_LOOP_URL_PREFIX=/loop/
CARTOSKY_WORKERS=4

# Boundary vector tiles served directly by the main API under /tiles/v3/boundaries/v1/*
CARTOSKY_BOUNDARIES_MBTILES=/opt/cartosky/data/boundaries/v1/cartosky_boundaries.mbtiles
CARTOSKY_BOUNDARIES_TILESET_ID=cartosky-boundaries-v1
CARTOSKY_BOUNDARIES_TILESET_NAME=CartoSky Boundaries v1
CARTOSKY_TILES_PUBLIC_BASE_URL=https://api.cartosky.com

CARTOSKY_SCHEDULER_VARS=tmp2m,tmp850,precip_total,snowfall_total,wspd10m,refc,radar_ptype
CARTOSKY_SCHEDULER_PRIMARY_VARS=tmp2m
CARTOSKY_SCHEDULER_POLL_SECONDS=300
CARTOSKY_SCHEDULER_KEEP_RUNS=2
CARTOSKY_SCHEDULER_PROBE_VAR=tmp2m

# Loop WebP pre-generation (post-publish)
CARTOSKY_LOOP_PREGENERATE_ENABLED=1
CARTOSKY_LOOP_CACHE_ROOT=/opt/cartosky/data/loop_cache
CARTOSKY_LOOP_PREGENERATE_WORKERS=4
CARTOSKY_LOOP_WEBP_QUALITY=82
CARTOSKY_LOOP_WEBP_MAX_DIM=2300
CARTOSKY_LOOP_WEBP_TIER0_FIXED_W=2300
CARTOSKY_LOOP_WEBP_TIER1_MAX_DIM=2400
CARTOSKY_LOOP_WEBP_TIER1_QUALITY=86
CARTOSKY_LOOP_WEBP_TIER1_FIXED_W=2400

# Grid substrate capability exposure (recommended prod posture: use code-supported defaults)
CARTOSKY_GRID_V1_ENABLED=1
# Leave CARTOSKY_GRID_V1_ALLOWLIST and CARTOSKY_GRID_V1_DENYLIST unset in prod.
# Current code-supported defaults:
#   HRRR: tmp2m, dp2m, tmp850, wspd10m, wgst10m, radar_ptype, precip_total, snowfall_total, snowfall_kuchera_total
#   GFS:  tmp2m, dp2m, tmp850, wspd10m, wgst10m, precip_total, snowfall_total
#   NAM:  tmp2m, dp2m, tmp850, wspd10m, wgst10m, radar_ptype, precip_total, snowfall_total
#   NBM:  tmp2m, wspd10m, precip_total, snowfall_total
#   MRMS: reflectivity

# Herbie subset fetch controls (still subset-only, no full-file fallback)
CARTOSKY_HERBIE_PRIORITY=aws,nomads,google,azure,pando,pando2
CARTOSKY_HERBIE_SUBSET_RETRIES=2
CARTOSKY_HERBIE_RETRY_SLEEP_SECONDS=0.6
HERBIE_SAVE_DIR=/opt/cartosky/herbie_cache

# CartoSky forums OAuth and REST API settings
TWF_BASE=https://theweatherforums.com
TWF_CLIENT_ID=<client id here>
TWF_CLIENT_SECRET=<secret here>
TWF_REDIRECT_URI=https://api.cartosky.com/auth/twf/callback
TWF_FORUMS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/forums
TWF_TOPICS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/topics
TWF_SCOPES="profile forums_posts"
FRONTEND_RETURN=https://cartosky.com
SESSION_COOKIE_NAME=cartosky_session
OAUTH_COOKIE_NAME=cartosky_twf_oauth
TOKEN_DB_PATH=/var/lib/cartosky/oauth_tokens.sqlite3
TOKEN_ENC_KEY=<enc key here>
TWF_API_KEY=<api key here>
CORS_ORIGINS=https://cartosky.com

# Admin telemetry + dashboard
CARTOSKY_TELEMETRY_DB_PATH=/var/lib/cartosky/admin_telemetry.sqlite3
CARTOSKY_STATUS_DB_PATH=/var/lib/cartosky/admin_status.sqlite3
CARTOSKY_ADMIN_MEMBER_IDS=12345
CARTOSKY_LEGACY_TELEMETRY_WRITE_ENABLED=1

# Prometheus / tracing rollout
CARTOSKY_PROMETHEUS_ENABLED=0
CARTOSKY_OTEL_ENABLED=0
CARTOSKY_OTEL_SERVICE_NAME=cartosky-api
CARTOSKY_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
CARTOSKY_OTEL_SAMPLE_RATIO=0.05
CARTOSKY_OTEL_SLOW_REQUEST_MS=1000
