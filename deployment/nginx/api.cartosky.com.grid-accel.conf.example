# Insert this location block inside the existing `server {}` for `api.cartosky.com`
# after proxy locations are defined. It must stay `internal` so clients cannot hit
# it directly; the API returns `X-Accel-Redirect` only after validating the file.
#
# This alias path must match `CARTOSKY_DATA_ROOT/published/`.
# This URI prefix must match `CARTOSKY_GRID_ACCEL_REDIRECT_PREFIX`.

location ^~ /_cartosky_grid_internal/ {
    internal;
    alias /opt/cartosky/data/published/;

    default_type application/octet-stream;

    # Prefer precompressed .br sidecars when the nginx Brotli static module is
    # available, then fall back to .gz sidecars, then to the raw grid binary.
    # Install/enable ngx_brotli or the distro equivalent before turning this on.
    brotli_static on;

    # Prefer precompressed .gz sidecars generated during grid publishing.
    # nginx will fall back to the raw grid artifact automatically when
    # a .gz sidecar is not present.
    gzip_static on;

    # These files are immutable published artifacts. Avoid recompressing origin
    # fills here; Cloudflare can still cache and serve them at the edge.
    gzip off;

    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Expose-Headers "Accept-Ranges, Cache-Control, CF-Cache-Status, Content-Encoding, Content-Length, ETag, Server-Timing, X-Request-ID, X-Trace-ID" always;
    add_header Vary "Accept-Encoding, Origin" always;
    add_header Cross-Origin-Resource-Policy "cross-origin" always;
}
